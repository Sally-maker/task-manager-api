# Application
PORT=3000

# PostgreSQL
DATABASE_URL="postgresql://taskuser:taskpassword@localhost:5432/taskmanager"

# Docker PostgreSQL (used by docker-compose)
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=taskpassword
POSTGRES_DB=taskmanager

# JWT — change this to a strong random value in production
# Access token expiry: 15 minutes (hardcoded)
# Refresh token expiry: 30 days (hardcoded)
JWT_SECRET="change-me-to-a-strong-random-secret"
