generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id            String         @id @default(uuid())
    name          String
    email         String         @unique
    password      String
    createdAt     DateTime       @default(now())
    tasks         Task[]
    refreshTokens RefreshToken[]
}

model RefreshToken {
    id        String   @id @default(uuid())
    token     String   @unique
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    expiresAt DateTime
    createdAt DateTime @default(now())
}

model Task {
    id          String     @id @default(uuid())
    title       String
    description String?
    status      TaskStatus @default(PENDING)
    createdAt   DateTime   @default(now())
    updatedAt   DateTime   @updatedAt
    userId      String
    user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum TaskStatus {
    PENDING
    IN_PROGRESS
    COMPLETED
}
